{
  "name": "pixi-game",
  "version": "1.0.0",
  "description": "Card RPG game on PixiJS",
  "type": "module",
  "scripts": {
    "dev": "vite --no-open --host",
    "prebuild": "node scripts/generate-version.cjs",
    "postbuild": "cp -n public/local_config.json dist/ 2>/dev/null || true",
    "build": "vite build",
    "build:fast": "vite build --config vite.config.fast.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "events": "^3.3.0",
    "pixi.js": "^7.4.0"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.1",
    "vite": "^5.4.0",
    "vite-plugin-obfuscator": "^1.0.5",
    "vite-plugin-singlefile": "^0.13.5"
  }
}
